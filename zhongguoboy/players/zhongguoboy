        .video-list, .fan-list { display: flex; flex-direction: column; gap: 1rem; }
        .video-card, .fan-card { background: #1e293b; border-radius: 1rem; padding: 1rem; }
        .video-card iframe { width: 100%; height: 220px; border-radius: 0.75rem; margin-top: 0.5rem; }
        .fan-card a { color: #FFB347; text-decoration: none; }
        .quote {
            font-style: italic;
            background: #1a1f2e;
            padding: 1rem;
            border-radius: 1rem;
            margin-top: 1rem;
            border-left: 3px solid #FF6F00;
            color: #cbd5e6;
        }
        footer { text-align: center; margin-top: 2rem; padding-top: 1rem; border-top: 1px solid #1e293b; color: #64748b; font-size: 0.8rem; }
        @media (max-width: 640px) { .video-card iframe { height: 160px; } }
