        body { background: #0a0f1f; font-family: 'Segoe UI', system-ui; color: #eef2ff; padding: 1.5rem; }
        .container { max-width: 1100px; margin: 0 auto; }
        .back-link { display: inline-block; margin-bottom: 1.5rem; color: #FFB347; text-decoration: none; font-weight: 500; }
        .back-link:hover { color: #FF6F00; transform: translateX(-3px); }
        .profile-card {
