        .subtitle { text-align: center; color: #94a3b8; margin-bottom: 1.5rem; }
        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
            margin: 1.5rem 0;
        }
        .info-item { background: #1e293b; padding: 0.75rem; border-radius: 1rem; text-align: center; }
        .info-label { font-size: 0.75rem; color: #FFB347; text-transform: uppercase; }
        .info-value { font-weight: bold; margin-top: 0.25rem; }
